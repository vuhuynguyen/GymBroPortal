{
  "name": "gym-bro-portal",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "rm -rf .angular/cache && ng serve",
    "build": "rm -rf .angular/cache && ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "generate:api": "openapi-generator-cli generate -i openapi.json -g typescript-angular -o src/app/api/generated --additional-properties=ngVersion=21,fileNaming=kebab-case,enumNameSuffix=''",
    "generate:api:live": "openapi-generator-cli generate -i http://localhost:5216/openapi/v1.json -g typescript-angular -o src/app/api/generated --additional-properties=ngVersion=21,fileNaming=kebab-case,enumNameSuffix=''",
    "check:api": "node scripts/check-api.mjs"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^22.0.1",
    "@angular/cdk": "^22.0.1",
    "@angular/common": "^22.0.1",
    "@angular/compiler": "^22.0.1",
    "@angular/core": "^22.0.1",
    "@angular/forms": "^22.0.1",
    "@angular/platform-browser": "^22.0.1",
    "@angular/platform-browser-dynamic": "^22.0.1",
    "@angular/router": "^22.0.1",
    "@primeuix/themes": "^2.0.3",
    "primeicons": "^7.0.0",
    "primeng": "^21.1.5",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "^0.16.1"
  },
  "devDependencies": {
    "@openapitools/openapi-generator-cli": "^2.13.4",
    "@angular-devkit/build-angular": "^22.0.1",
    "@angular/cli": "^22.0.1",
    "@angular/compiler-cli": "^22.0.1",
    "@types/jasmine": "~5.1.0",
    "autoprefixer": "^10.4.27",
    "jasmine-core": "~5.1.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.9.3"
  }
}
